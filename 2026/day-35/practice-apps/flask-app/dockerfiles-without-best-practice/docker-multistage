# === This is first stage =====

FROM python:3.11-slim AS build

WORKDIR /app

COPY requirements.txt .

RUN pip install -r requirements.txt --no-cache --target=/app/dist
 
COPY . .

# ======== This is Second stage ==============

FROM python:3.11-alpine

WORKDIR /app

COPY --from=build /app /app

ENV PYTHONPATH=/app/dist

EXPOSE 5000

CMD ["python","app.py"] 
